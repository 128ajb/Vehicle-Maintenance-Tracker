<?xml version="1.0" encoding="UTF-8"?>

<!DOCTYPE mapper
    PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
    "https://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.FinalProject.MaintenanceTracker.mapper.UserMapper">

    <select id="login"
            parameterType="com.FinalProject.MaintenanceTracker.model.User"
            resultType="com.FinalProject.MaintenanceTracker.model.User">

        SELECT
            user_id AS userId,
            username,
            password

        FROM "Users"

        WHERE username = #{username}
          AND password = #{password}

    </select>

    <insert id="insert">

        INSERT INTO "Users"
        (
            username,
            password
        )

        VALUES
        (
            #{username},
            #{password}
        )

    </insert>

</mapper>